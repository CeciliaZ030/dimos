# Copy to .env.local and fill in.
#
# VITE_DIMOS_API
#   Full URL to the dimos FastAPI backend, no trailing slash.
#   Local dev:  http://localhost:5555
#   Tailscale:  https://go2-jetson.<your-tailnet>.ts.net:8443
#   Vercel:     same as Tailscale URL
#
# VITE_DIMOS_TOKEN
#   Bearer token configured on the backend via the DIMOS_API_TOKEN env var.
#   Empty disables auth (only for local dev when DIMOS_API_TOKEN is also unset).
#   The token is appended to SSE URLs as ?token=... because EventSource
#   cannot set headers.

VITE_DIMOS_API=http://localhost:5555
VITE_DIMOS_TOKEN=
